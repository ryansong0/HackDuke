{
  "manifest_version": 3,
  "name": "EcoSwap: Amazon Sustainability Assistant",
  "version": "1.0.0",
  "description": "Find eco-friendly alternatives while you shop on Amazon.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://www.amazon.com/*", "https://*.run.app/*"],
  "action": {
    "default_popup": "index.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.amazon.com/*"],
      "js": ["assets/content.js"],
      "css": ["assets/index.css"]
    }
  ]
}
